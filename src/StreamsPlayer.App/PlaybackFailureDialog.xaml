<Window x:Class="StreamsPlayer.App.PlaybackFailureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource StreamUnavailableTitle}" Height="180" Width="520" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource WindowBackground}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" VerticalAlignment="Top" />
        <TextBlock x:Name="CopiedText" Grid.Row="1" Visibility="Collapsed" Margin="0,10,0,0"
                   Foreground="{StaticResource AccentBrush}" Text="{DynamicResource FailureReportCopied}" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="RetryButton" Content="{DynamicResource FailureRetry}" Click="Retry_Click" IsDefault="True" Margin="6,0,0,0" Padding="14,6" />
            <Button x:Name="CopyButton" Content="{DynamicResource FailureCopyReport}" Click="CopyReport_Click" Margin="6,0,0,0" Padding="14,6" />
            <Button x:Name="RemoveButton" Content="{DynamicResource FailureDelete}" Click="Remove_Click" Margin="6,0,0,0" Padding="14,6" />
            <Button x:Name="KeepButton" Content="{DynamicResource FailureKeep}" Click="Keep_Click" IsCancel="True" Margin="6,0,0,0" Padding="14,6" />
        </StackPanel>
    </Grid>
</Window>
