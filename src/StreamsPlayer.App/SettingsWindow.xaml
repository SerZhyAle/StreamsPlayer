<Window x:Class="StreamsPlayer.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource SettingsWindowTitle}" Width="620" Height="480"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource WindowBackground}">
    <Window.Resources>
        <!-- Monochrome tab-strip icon, matching the app's glyph vocabulary. -->
        <Style x:Key="TabIcon" TargetType="Path">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Margin" Value="0,0,9,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Fill" Value="#FF172236" />
            <Setter Property="Stroke" Value="#FF172236" />
            <Setter Property="StrokeThickness" Value="1.4" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl TabStripPlacement="Left" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="#FFD5DCE6" Padding="14">

            <!-- Grid / Layout -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource TabIcon}" Data="M4,4H10V10H4ZM14,4H20V10H14ZM4,14H10V20H4ZM14,14H20V20H14Z" />
                        <TextBlock Text="{DynamicResource GridSettings}" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <StackPanel>
                    <TextBlock Text="{DynamicResource StreamTileSizeLabel}" FontWeight="SemiBold" />
                    <ComboBox x:Name="TileSizeBox" Margin="0,5,0,12" HorizontalAlignment="Stretch"
                              AutomationProperties.Name="{DynamicResource StreamTileSizeLabel}" />
                    <CheckBox x:Name="UpdatePreviewsCheckBox" Content="{DynamicResource UpdateStreamPreviews}"
                              ToolTip="{DynamicResource UpdateStreamPreviewsTip}"
                              AutomationProperties.Name="{DynamicResource UpdateStreamPreviews}" />
                </StackPanel>
            </TabItem>

            <!-- Launch shortcuts -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource TabIcon}" Data="M10,14L14,10M8,16H6A4,4 0 0 1 6,8H10M16,8H18A4,4 0 0 1 18,16H14" Fill="Transparent" />
                        <TextBlock Text="{DynamicResource LaunchShortcuts}" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <StackPanel>
                    <TextBlock x:Name="SelectedStreamText" Margin="0,0,0,10" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                    <WrapPanel>
                        <Button x:Name="CopyLaunchCommandButton" Style="{StaticResource LinkGlyphButton}" Content="{DynamicResource CopyLaunchCommand}"
                                Click="CopyLaunchCommand_Click" ToolTip="{DynamicResource CopyLaunchCommandTip}" />
                        <Button x:Name="CreateDesktopShortcutButton" Style="{StaticResource ShortcutGlyphButton}" Content="{DynamicResource CreateDesktopShortcut}"
                                Click="CreateDesktopShortcut_Click" ToolTip="{DynamicResource CreateDesktopShortcutTip}" />
                    </WrapPanel>
                </StackPanel>
            </TabItem>

            <!-- Playback -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource TabIcon}" Data="M7,4L20,12L7,20Z" />
                        <TextBlock Text="{DynamicResource PlaybackSettings}" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <StackPanel>
                    <CheckBox x:Name="KeepAwakeCheckBox" ToolTip="{DynamicResource KeepAwakeDuringPlaybackTip}"
                              AutomationProperties.Name="{DynamicResource KeepAwakeDuringPlayback}">
                        <TextBlock Text="{DynamicResource KeepAwakeDuringPlayback}" TextWrapping="Wrap" />
                    </CheckBox>
                    <CheckBox x:Name="SystemMediaControlsCheckBox" Margin="0,10,0,0"
                              ToolTip="{DynamicResource SystemMediaControlsTip}"
                              AutomationProperties.Name="{DynamicResource SystemMediaControls}">
                        <TextBlock Text="{DynamicResource SystemMediaControls}" TextWrapping="Wrap" />
                    </CheckBox>
                    <TextBlock Text="{DynamicResource VideoBackendLabel}" FontWeight="SemiBold" Margin="0,16,0,0" />
                    <ComboBox x:Name="VideoBackendBox" Margin="0,5,0,0" HorizontalAlignment="Stretch"
                              AutomationProperties.Name="{DynamicResource VideoBackendLabel}" />
                    <TextBlock Text="{DynamicResource VideoBackendHint}" Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" Margin="0,5,0,0" />
                </StackPanel>
            </TabItem>

            <!-- Playlists (M3U) import/export -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource TabIcon}" Data="M4,5H20M4,12H14M4,19H14M17,15V21M14,18L17,21L20,18" Fill="Transparent" />
                        <TextBlock Text="{DynamicResource PlaylistPortability}" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <StackPanel>
                    <TextBlock Text="{DynamicResource PlaylistPortabilityHint}" Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10" />
                    <WrapPanel>
                        <Button x:Name="ImportFromFileButton" Style="{StaticResource ImportGlyphButton}"
                                Content="{DynamicResource ImportFromFile}" Click="ImportFromFile_Click"
                                ToolTip="{DynamicResource ImportListTip}" />
                        <Button x:Name="ImportFromUrlButton" Style="{StaticResource ImportGlyphButton}"
                                Content="{DynamicResource ImportFromUrl}" Click="ImportFromUrl_Click"
                                ToolTip="{DynamicResource ImportListTip}" />
                        <Button x:Name="ExportAllButton" Style="{StaticResource ExportGlyphButton}"
                                Content="{DynamicResource ExportAll}" Click="ExportAll_Click"
                                ToolTip="{DynamicResource ExportListTip}" />
                        <Button x:Name="ExportPinnedButton" Style="{StaticResource ExportGlyphButton}"
                                Content="{DynamicResource ExportPinned}" Click="ExportPinned_Click"
                                ToolTip="{DynamicResource ExportListTip}" />
                    </WrapPanel>
                </StackPanel>
            </TabItem>

            <!-- About -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource TabIcon}" Data="M12,3A9,9 0 1 0 12,21A9,9 0 1 0 12,3M11.35,6.6H12.65V7.9H11.35ZM12,10.4V16.6" Fill="Transparent" />
                        <TextBlock Text="{DynamicResource About}" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <StackPanel>
                    <TextBlock Text="{DynamicResource ProductName}" FontSize="24" FontWeight="SemiBold" Foreground="#FF172236" />
                    <Grid Margin="0,8,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource VersionLabel}" FontWeight="SemiBold" Margin="0,0,10,5" />
                        <TextBlock x:Name="VersionText" Grid.Column="1" Margin="0,0,0,5" />
                        <TextBlock Grid.Row="1" Text="{DynamicResource AuthorLabel}" FontWeight="SemiBold" Margin="0,0,10,0" />
                        <TextBlock x:Name="AuthorText" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" />
                    </Grid>
                    <WrapPanel>
                        <TextBlock Margin="0,0,18,8">
                            <Hyperlink Foreground="#FF0067C0" TextDecorations="Underline" Tag="Instructions"
                                       Click="OpenLink_Click" ToolTip="{DynamicResource DocumentationTip}"
                                       AutomationProperties.Name="{DynamicResource Documentation}">
                                <Run Text="{DynamicResource Documentation}" />
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,0,18,8">
                            <Hyperlink Foreground="#FF0067C0" TextDecorations="Underline" Tag="Source"
                                       Click="OpenLink_Click" ToolTip="{DynamicResource SourceCodeTip}"
                                       AutomationProperties.Name="{DynamicResource SourceCode}">
                                <Run Text="{DynamicResource SourceCode}" />
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,0,18,8">
                            <Hyperlink Foreground="#FF0067C0" TextDecorations="Underline" Tag="Website"
                                       Click="OpenLink_Click" ToolTip="{DynamicResource WebsiteTip}"
                                       AutomationProperties.Name="{DynamicResource Website}">
                                <Run Text="{DynamicResource Website}" />
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,0,18,8">
                            <Hyperlink Foreground="#FF0067C0" TextDecorations="Underline" Tag="Privacy"
                                       Click="OpenLink_Click" ToolTip="{DynamicResource PrivacyTip}"
                                       AutomationProperties.Name="{DynamicResource Privacy}">
                                <Run Text="{DynamicResource Privacy}" />
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,0,18,8">
                            <Hyperlink Foreground="#FF0067C0" TextDecorations="Underline" Tag="Author"
                                       Click="OpenLink_Click" ToolTip="{DynamicResource AuthorPageTip}"
                                       AutomationProperties.Name="{DynamicResource AuthorPage}">
                                <Run Text="{DynamicResource AuthorPage}" />
                            </Hyperlink>
                        </TextBlock>
                    </WrapPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Style="{StaticResource CancelGlyphButton}" Content="{DynamicResource Cancel}" Click="Cancel_Click" />
            <Button Style="{StaticResource ConfirmGlyphButton}" Content="{DynamicResource Save}" Click="Save_Click"
                    IsDefault="True" Background="{StaticResource AccentBrush}" Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
