<Window x:Class="StreamsPlayer.App.HiddenChannelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ManageHiddenTitle}" Height="420" Width="560"
        WindowStartupLocation="CenterOwner" Background="{StaticResource WindowBackground}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="EmptyText" Text="{DynamicResource HiddenChannelsEmpty}" Visibility="Collapsed"
                   VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.7" />
        <ListBox x:Name="HiddenList" BorderThickness="0" Background="Transparent"
                 HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding RedactedUrl}" Opacity="0.65" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="{DynamicResource Unhide}" Tag="{Binding}" Click="Unhide_Click"
                                VerticalAlignment="Center" Margin="10,0,0,0" Padding="12,5" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{DynamicResource Close}" IsCancel="True" Padding="14,6" />
        </StackPanel>
    </Grid>
</Window>
