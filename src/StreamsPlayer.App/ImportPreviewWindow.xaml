<Window x:Class="StreamsPlayer.App.ImportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ImportPreviewTitle}" Height="300" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource WindowBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="SourceText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,0,12" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="{DynamicResource ImportCountNew}" Margin="0,3" />
            <TextBlock x:Name="NewCountText" Grid.Column="1" Margin="0,3" FontWeight="SemiBold" />
            <TextBlock Grid.Row="1" Text="{DynamicResource ImportCountDuplicate}" Margin="0,3" />
            <TextBlock x:Name="DuplicateCountText" Grid.Row="1" Grid.Column="1" Margin="0,3" />
            <TextBlock Grid.Row="2" Text="{DynamicResource ImportCountInvalid}" Margin="0,3" />
            <TextBlock x:Name="InvalidCountText" Grid.Row="2" Grid.Column="1" Margin="0,3" />
            <TextBlock Grid.Row="3" Text="{DynamicResource ImportCountSkipped}" Margin="0,3" />
            <TextBlock x:Name="SkippedCountText" Grid.Row="3" Grid.Column="1" Margin="0,3" />
        </Grid>
        <TextBlock x:Name="ExplanationText" Grid.Row="2" TextWrapping="Wrap" Opacity="0.75"
                   VerticalAlignment="Bottom" Margin="0,14,0,0" />
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="ApplyButton" Content="{DynamicResource ImportApply}" Click="Apply_Click"
                    IsDefault="True" Padding="16,6" Margin="0,0,8,0"
                    Background="{StaticResource AccentBrush}" Foreground="White" />
            <Button Content="{DynamicResource Cancel}" IsCancel="True" Padding="14,6" />
        </StackPanel>
    </Grid>
</Window>
