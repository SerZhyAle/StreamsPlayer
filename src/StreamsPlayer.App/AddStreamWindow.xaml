<Window x:Class="StreamsPlayer.App.AddStreamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AddWindowTitle}" Width="560" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource WindowBackground}">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource StreamUrlLabel}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox x:Name="UrlBox" Grid.Row="0" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource TitleOptional}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox x:Name="TitleBox" Grid.Row="1" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource FieldType}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <ComboBox x:Name="MediaKindBox" Grid.Row="2" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Category}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox x:Name="CategoryBox" Grid.Row="3" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource FieldTopic}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox x:Name="TopicBox" Grid.Row="4" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource Language}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox x:Name="LanguageBox" Grid.Row="5" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource Country}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox x:Name="CountryBox" Grid.Row="6" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource FieldHomepage}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox x:Name="HomepageBox" Grid.Row="7" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource FieldProtocol}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox x:Name="ProtocolBox" Grid.Row="8" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="9" Grid.Column="0" Text="{DynamicResource FieldFormat}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox x:Name="FormatBox" Grid.Row="9" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="10" Grid.Column="0" Text="{DynamicResource FieldBitrate}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox x:Name="BitrateBox" Grid.Row="10" Grid.Column="1" Margin="0,5" Padding="7" />

        <TextBlock Grid.Row="11" Grid.Column="0" Text="{DynamicResource LiveLabel}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <CheckBox x:Name="LiveBox" Grid.Row="11" Grid.Column="1" IsThreeState="True" VerticalAlignment="Center" Margin="0,8" />

        <StackPanel Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Style="{StaticResource CancelGlyphButton}" Content="{DynamicResource Cancel}" IsCancel="True" />
            <Button x:Name="ConfirmButton" Style="{StaticResource ConfirmGlyphButton}" Content="{DynamicResource Add}" IsDefault="True" Click="Add_Click" Background="{StaticResource AccentBrush}" Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
