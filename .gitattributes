# Normalize text, while retaining CRLF for Windows-oriented source files.
* text=auto

*.cs       text eol=crlf
*.csproj   text eol=crlf
*.sln      text eol=crlf
*.props    text eol=crlf
*.targets  text eol=crlf
*.ps1      text eol=crlf
*.xml      text eol=crlf
*.yml      text eol=crlf
*.yaml     text eol=crlf
*.md       text eol=crlf
*.html     text eol=crlf
*.css      text eol=crlf
*.txt      text eol=crlf

*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.msix binary
